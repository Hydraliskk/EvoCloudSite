---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    category: "Automobile",
    title: "Alma Toyota",
    description:
      "Transformation numérique d’envergure avec une infrastructure pensée pour améliorer l’expérience client et l’efficacité interne.",
    image: "/images/Toyota.jpg",
    alt: "Alma Toyota",
    tags: ["Architecture TI", "Sécurité d’entreprise", "Téléphonie IP", "Support TI"],
  },
  {
    category: "Santé",
    title: "Clinique médicale d’Alma",
    description:
      "Soutien à un milieu où la stabilité, la fluidité des communications et la continuité opérationnelle sont essentielles.",
    image: "/images/Clinique_medical.jpg",
    alt: "Clinique médicale d'Alma",
    tags: ["Support TI", "Continuité", "Fiabilité", "Accompagnement"],
  },
  {
    category: "Automobile",
    title: "Piece Auto Choc",
    description:
      "Accompagnement technologique pour un environnement professionnel qui demande de la structure et de la fiabilité.",
    image: "/images/PieceAuto.png",
    alt: "Piece Auto Choc",
    tags: ["Sécurité", "Segmentation réseaux", "Modernisation", "Réseau"],
  },
  {
    category: "Construction",
    title: "Construction BlackBurn et Fils",
    description:
      "Une base technologique pensée pour soutenir la croissance et garder une structure claire autour des opérations.",
    image: "/images/ConstructionBlackBurn.jpg",
    alt: "Construction BlackBurn et Fils",
    tags: ["Collaboration", "Cloud", "Évolutivité", "Support"],
  },
  {
    category: "Financier",
    title: "Service Financier du Lac",
    description:
      "Déploiement d’une posture de sécurité plus solide, avec des recommandations concrètes et faciles à maintenir.",
    image: "/images/CFDL.png",
    alt: "Illustration cybersécurité",
    tags: ["Audit", "Accès", "Prévention", "Surveillance"],
  },
  {
    category: "Notaire",
    title: "Simard Monast",
    description:
      "Accompagnement cloud pour simplifier la collaboration, la mobilité et la continuité de service.",
    image: "/images/SME.png",
    alt: "Illustration cloud",
    tags: ["Microsoft 365", "Sauvegarde", "Support", "Migration"],
  },
];
---

<BaseLayout title="Réalisations | Evolution Cloud">
  <main class="overflow-hidden">
    <section class="relative isolate mx-auto max-w-7xl px-6 py-16 md:py-24">
      <div class="absolute -left-24 top-16 h-72 w-72 rounded-full bg-cyan-400/12 blur-3xl"></div>
      <div class="max-w-3xl">
        <h1 class="mt-5 text-4xl font-semibold tracking-tight text-white md:text-6xl">
          Nos réalisations
        </h1>
        <p class="mt-6 text-lg leading-8 text-slate-300">
          Voici quelques mandats récents que nous avons réalisés.
        </p>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 pb-16 md:pb-24">
      <div class="relative rounded-[2.75rem] border border-cyan-300/45 bg-[linear-gradient(180deg,rgba(4,10,24,0.95),rgba(8,15,35,0.94))] px-4 py-5 shadow-[0_34px_110px_-42px_rgba(14,165,233,0.5)] ring-1 ring-cyan-200/24 md:px-5 md:py-6" data-carousel-shell>
        <div class="mb-4 flex items-center justify-between gap-4 px-2 md:px-3">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-300">Projets</p>
          </div>
          <div class="flex flex-col items-end gap-3">
            <div class="hidden items-center gap-2 md:flex">
              <button
                type="button"
                class="carousel-btn inline-flex h-11 w-11 items-center justify-center rounded-full border border-cyan-300/30 bg-white/5 text-cyan-100 transition hover:border-cyan-100/70 hover:bg-cyan-300/12"
                data-carousel-prev
                aria-label="Voir le projet précédent"
              >
                <span class="text-xl leading-none">‹</span>
              </button>
              <button
                type="button"
                class="carousel-btn inline-flex h-11 w-11 items-center justify-center rounded-full border border-cyan-300/30 bg-white/5 text-cyan-100 transition hover:border-cyan-100/70 hover:bg-cyan-300/12"
                data-carousel-next
                aria-label="Voir le projet suivant"
              >
                <span class="text-xl leading-none">›</span>
              </button>
            </div>
            <div class="carousel-dots flex items-center gap-2 px-1" data-carousel-dots aria-label="Progression des projets"></div>
          </div>
        </div>

        <div
          class="carousel-track flex gap-4 overflow-x-auto px-2 pb-2 pt-1 md:gap-5 md:px-3"
          data-carousel-track
        >
          {projects.map((project, index) => (
            <article
              class="carousel-card group relative min-w-[84vw] overflow-hidden rounded-[2.5rem] border border-cyan-300/35 bg-[linear-gradient(180deg,rgba(4,10,24,0.95),rgba(10,18,38,0.94))] shadow-[0_30px_84px_-38px_rgba(14,165,233,0.5)] ring-1 ring-cyan-200/18 transition duration-300 hover:-translate-y-0.5 hover:shadow-[0_34px_96px_-34px_rgba(34,211,238,0.58)] md:min-w-[34rem] lg:min-w-[38rem]"
              data-carousel-card
              data-carousel-index={index}
              style={`--card-delay:${index * 120}ms;`}
            >
              <div class="relative">
                <img src={project.image} alt={project.alt} class="block aspect-[16/10] w-full object-cover object-center transition duration-500 group-hover:scale-105" />
                <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(2,6,23,0.16),rgba(2,6,23,0.72))]"></div>
              </div>
              <div class="p-6 md:p-7">
                <div class="flex flex-wrap items-center gap-3">
                  <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-300">{project.category}</p>
                </div>
                <h3 class="mt-3 text-2xl font-semibold tracking-tight text-white md:text-[2.1rem]">{project.title}</h3>
                <p class="mt-4 text-sm leading-6 text-slate-300 md:text-base">{project.description}</p>
                <div class="mt-5 flex flex-wrap gap-2.5">
                  {project.tags.map((tag) => (
                    <span class="rounded-full border border-cyan-300/25 bg-white/5 px-3 py-1 text-xs font-medium text-cyan-200">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>

        <div class="mt-4 flex items-center justify-between px-2 md:hidden">
          <button
            type="button"
            class="carousel-btn inline-flex h-11 w-11 items-center justify-center rounded-full border border-cyan-300/30 bg-white/5 text-cyan-100 transition hover:border-cyan-100/70 hover:bg-cyan-300/12"
            data-carousel-prev
            aria-label="Voir le projet précédent"
          >
            <span class="text-xl leading-none">‹</span>
          </button>
          <button
            type="button"
            class="carousel-btn inline-flex h-11 w-11 items-center justify-center rounded-full border border-cyan-300/30 bg-white/5 text-cyan-100 transition hover:border-cyan-100/70 hover:bg-cyan-300/12"
            data-carousel-next
            aria-label="Voir le projet suivant"
          >
            <span class="text-xl leading-none">›</span>
          </button>
        </div>
        <div class="mt-4 flex items-center justify-center gap-2 md:hidden" data-carousel-dots aria-label="Progression des projets"></div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 pb-20 md:pb-28">
      <div class="rounded-[2.5rem] border border-cyan-300/50 bg-[linear-gradient(180deg,rgba(4,10,24,0.96),rgba(2,6,23,1))] px-7 py-10 text-white shadow-[0_38px_118px_-36px_rgba(14,165,233,0.48)] ring-1 ring-cyan-200/26 md:px-10">
        <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-end">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-cyan-300">Lecture rapide</p>
            <h2 class="mt-4 max-w-2xl text-3xl font-semibold tracking-tight md:text-4xl">
              Des projets concrets, pas seulement des technologies.
            </h2>
            <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">
              L’objectif est toujours le même: créer des bases plus simples à exploiter, plus fiables à maintenir et plus utiles pour les équipes.
            </p>
          </div>
          <a href="/contact" class="inline-flex w-fit rounded-full border border-cyan-300/30 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-cyan-300/12">
            Discuter d’un mandat
          </a>
        </div>
      </div>
    </section>
  </main>

  <script>
    const setupCarousel = (track, prevButtons, nextButtons) => {
      const scrollByAmount = (direction) => {
        const card = track.querySelector(".carousel-card");
        const amount = card ? card.getBoundingClientRect().width + 20 : track.clientWidth * 0.8;
        track.scrollBy({ left: direction * amount, behavior: "smooth" });
      };

      prevButtons.forEach((button) => {
        button.addEventListener("pointerdown", (event) => {
          event.stopPropagation();
        });
        button.addEventListener("click", (event) => {
          event.preventDefault();
          event.stopPropagation();
          scrollByAmount(-1);
        });
      });

      nextButtons.forEach((button) => {
        button.addEventListener("pointerdown", (event) => {
          event.stopPropagation();
        });
        button.addEventListener("click", (event) => {
          event.preventDefault();
          event.stopPropagation();
          scrollByAmount(1);
        });
      });
    };

    const track = document.querySelector("[data-carousel-track]");
    const shell = document.querySelector("[data-carousel-shell]");
    const prevButtons = Array.from(document.querySelectorAll("[data-carousel-prev]"));
    const nextButtons = Array.from(document.querySelectorAll("[data-carousel-next]"));
    const cards = Array.from(document.querySelectorAll("[data-carousel-card]"));
    const dotGroups = Array.from(document.querySelectorAll("[data-carousel-dots]"));

    if (track && prevButtons.length && nextButtons.length) {
      setupCarousel(track, prevButtons, nextButtons);
    }

    if (shell && track) {
      shell.addEventListener(
        "wheel",
        (event) => {
          const canScrollHorizontally = track.scrollWidth > track.clientWidth;
          if (!canScrollHorizontally) {
            return;
          }

          const horizontalDelta = Math.abs(event.deltaX);
          const verticalDelta = Math.abs(event.deltaY);
          const delta = horizontalDelta > verticalDelta ? event.deltaX : event.deltaY;

          if (delta === 0) {
            return;
          }

          event.preventDefault();
          track.scrollBy({
            left: delta,
            behavior: "auto",
          });
        },
        { passive: false },
      );
    }

    if (shell && track) {
      let isDragging = false;
      let dragStartX = 0;
      let dragStartScroll = 0;
      let activePointerId = null;

      const stopDrag = () => {
        isDragging = false;
        shell.dataset.dragging = "false";
        activePointerId = null;
      };

      const onPointerDown = (event) => {
        if (event.pointerType === "mouse" && event.button !== 0) {
          return;
        }

        if (event.target.closest("button, a, input, textarea, select, label")) {
          return;
        }

        isDragging = true;
        activePointerId = event.pointerId;
        dragStartX = event.clientX;
        dragStartScroll = track.scrollLeft;
        shell.dataset.dragging = "true";
        shell.setPointerCapture?.(event.pointerId);
      };

      const onPointerMove = (event) => {
        if (!isDragging || activePointerId !== event.pointerId) {
          return;
        }

        const delta = event.clientX - dragStartX;
        track.scrollLeft = dragStartScroll - delta;
      };

      const onPointerUp = (event) => {
        if (activePointerId !== event.pointerId) {
          return;
        }

        stopDrag();
        shell.releasePointerCapture?.(event.pointerId);
      };

      const onPointerCancel = () => {
        stopDrag();
      };

      shell.addEventListener("pointerdown", onPointerDown);
      shell.addEventListener("pointermove", onPointerMove);
      shell.addEventListener("pointerup", onPointerUp);
      shell.addEventListener("pointercancel", onPointerCancel);
      shell.addEventListener("lostpointercapture", onPointerCancel);
      shell.addEventListener("mouseleave", () => {
        if (isDragging) stopDrag();
      });
    }

    if (track && cards.length && dotGroups.length) {
      const dotButtons = [];

      dotGroups.forEach((group) => {
        group.innerHTML = "";
        cards.forEach((_, index) => {
          const dot = document.createElement("button");
          dot.type = "button";
          dot.className = "carousel-dot h-2.5 w-2.5 rounded-full border border-cyan-200/20 bg-cyan-200/25 transition duration-300";
          dot.setAttribute("aria-label", `Aller au projet ${index + 1}`);
          dot.addEventListener("click", () => {
            cards[index].scrollIntoView({ behavior: "smooth", inline: "center", block: "nearest" });
          });
          dotButtons.push(dot);
          group.appendChild(dot);
        });
      });

      const setActive = (activeIndex) => {
        dotButtons.forEach((dot, index) => {
          const isActive = index === activeIndex;
          dot.dataset.active = isActive ? "true" : "false";
          dot.className = isActive
            ? "carousel-dot h-2.5 w-2.5 rounded-full border border-cyan-100/60 bg-cyan-100 shadow-[0_0_18px_rgba(165,243,252,0.9)] transition duration-300"
            : "carousel-dot h-2.5 w-2.5 rounded-full border border-cyan-200/20 bg-cyan-200/25 transition duration-300";
        });
      };

      const getActiveIndex = () => {
        const trackRect = track.getBoundingClientRect();
        const center = trackRect.left + trackRect.width / 2;
        let bestIndex = 0;
        let bestDistance = Number.POSITIVE_INFINITY;

        cards.forEach((card, index) => {
          const rect = card.getBoundingClientRect();
          const cardCenter = rect.left + rect.width / 2;
          const distance = Math.abs(center - cardCenter);
          if (distance < bestDistance) {
            bestDistance = distance;
            bestIndex = index;
          }
        });

        return bestIndex;
      };

      let rafId = 0;
      const updateActive = () => setActive(getActiveIndex());
      const onScroll = () => {
        window.cancelAnimationFrame(rafId);
        rafId = window.requestAnimationFrame(updateActive);
      };

      track.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", updateActive);
      updateActive();
    }
  </script>

  <style>
    .carousel-track {
      scroll-snap-type: x mandatory;
      scroll-snap-stop: always;
      scroll-padding-inline: 1rem;
      scroll-behavior: smooth;
      scrollbar-width: thin;
      scrollbar-color: rgba(125, 211, 252, 0.5) transparent;
      overscroll-behavior-x: contain;
      touch-action: pan-y;
      cursor: grab;
    }

    .carousel-track::-webkit-scrollbar {
      height: 8px;
    }

    .carousel-track::-webkit-scrollbar-track {
      background: transparent;
    }

    .carousel-track::-webkit-scrollbar-thumb {
      border-radius: 9999px;
      background: rgba(125, 211, 252, 0.45);
    }

    .carousel-card {
      scroll-snap-align: center;
      scroll-snap-stop: always;
      animation: card-enter 720ms cubic-bezier(0.16, 1, 0.3, 1) both;
      animation-delay: var(--card-delay);
      opacity: 0;
      transform: translateY(18px) scale(0.98);
    }

    [data-carousel-shell][data-dragging="true"] .carousel-track {
      cursor: grabbing;
      user-select: none;
    }

    .carousel-dot[data-active="true"] {
      transform: scale(1.15);
    }

    @keyframes card-enter {
      from {
        opacity: 0;
        transform: translateY(18px) scale(0.98);
      }

      to {
        opacity: 1;
        transform: translateY(0) scale(1);
      }
    }
  </style>
</BaseLayout>
