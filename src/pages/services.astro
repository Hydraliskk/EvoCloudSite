---
import BaseLayout from "../layouts/BaseLayout.astro";

const faqItems = [
  {
    question: "Quels types de services offrez-vous?",
    answer:
      "Nous offrons des services de cybersécurité, de cloud, de conformité à la Loi 25, de communication unifiée, de support technique et de bâtiments connectés.",
  },
  {
    question: "Comment se déroule un audit de sécurité?",
    answer:
      "L’audit de sécurité commence par un tour du parc informatique, des services utilisés, des accès et des équipements en place afin d’identifier les risques, les priorités et les améliorations à apporter.",
  },
  {
    question: "Offrez-vous du support Microsoft 365?",
    answer:
      "Oui. Nous pouvons vous accompagner pour Microsoft 365, Windows, les postes de travail, la configuration et le support courant.",
  },
  {
    question: "Pouvez-vous nous aider avec la Loi 25?",
    answer:
      "Oui. Nous offrons de l’accompagnement pour la conformité à la Loi 25, avec évaluation des obligations, politiques, procédures et mise en place.",
  },
  {
    question: "Faites-vous de l’installation et de la réparation?",
    answer:
      "Oui. Notre volet technique couvre l’installation, la réparation, le dépannage, la mise en service et l’assistance à distance ou sur site.",
  },
  {
    question: "Travaillez-vous aussi en dehors des heures d’ouverture?",
    answer:
      "Oui. Nous restons disponibles en dehors des heures aussi selon la nature du besoin et le niveau d’urgence.",
  },
  {
    question: "Offrez-vous des services sur site?",
    answer:
      "Oui. Nous pouvons intervenir à distance ou sur site, selon le service et la situation.",
  },
];

const serviceTickerItems = [
  "Cybersécurité",
  "Cloud",
  "Loi 25",
  "Support Microsoft 365",
  "Téléphonie IP",
  "Bâtiments connectés",
  "Sauvegarde",
  "Audit de sécurité",
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<BaseLayout title="Services | Evolution Cloud">
  <main class="overflow-hidden">
    <section class="relative isolate mx-auto max-w-7xl px-6 py-16 md:py-24">
      <div class="absolute -left-24 top-10 h-72 w-72 rounded-full bg-blue-100/70 blur-3xl"></div>
      <div class="absolute right-0 top-0 h-80 w-80 rounded-full bg-sky-100/60 blur-3xl"></div>
      <div class="absolute inset-x-0 top-20 h-px bg-gradient-to-r from-transparent via-blue-200/70 to-transparent"></div>

      <div class="relative">
        <div class="flex flex-col justify-center">
          <p class="inline-flex w-fit rounded-full border border-blue-200 bg-white/85 px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-blue-700 shadow-sm backdrop-blur">
            Nos services
          </p>
          <h1 class="mt-5 max-w-3xl text-4xl font-semibold tracking-tight text-slate-950 md:text-6xl">
            Une offre claire, structurée et rassurante pour vos opérations.
          </h1>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600">
            Evolution Cloud accompagne les entreprises en cybersécurité, cloud, Loi 25, communication unifiée, bâtiments connectés et support technique.
            L’idée est simple: des services concrets, bien cadrés et utiles au quotidien.
          </p>
          <p class="mt-4 max-w-3xl text-sm leading-7 text-slate-600">
            Nous desservons principalement le Lac-Saint-Jean et le Saguenay, avec possibilité d’interventions ailleurs selon le besoin.
          </p>

        </div>
      </div>
    </section>

    <section class="relative mx-auto max-w-6xl px-6 pb-16 md:pb-24">
      <div class="pointer-events-none absolute inset-x-10 top-8 h-40 rounded-full bg-blue-100/35 blur-3xl"></div>
      <div class="grid gap-6 xl:grid-cols-12 xl:auto-rows-[1fr]">
        <article class="relative overflow-hidden rounded-[2.25rem] border border-blue-100 bg-gradient-to-br from-blue-50 to-white p-7 shadow-[0_16px_40px_-30px_rgba(37,99,235,0.35)] xl:col-span-7 xl:min-h-[17rem]">
          <div class="absolute -right-10 -top-10 h-36 w-36 rounded-full bg-blue-100/50 blur-2xl"></div>
          <div class="flex items-center justify-between gap-4">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-700">Cybersécurité</p>
            <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">Priorité haute</span>
          </div>
          <h2 class="mt-3 text-2xl font-semibold text-slate-950">Protection de vos environnements</h2>
          <p class="mt-3 max-w-xl text-sm leading-6 text-slate-600">
            On sécurise vos systèmes avec une approche réaliste, orientée prévention, détection et réponse.
          </p>
          <ul class="mt-6 grid gap-3 text-sm leading-6 text-slate-600 sm:grid-cols-2">
            <li class="rounded-2xl border border-white/80 bg-white/70 px-3 py-2">Audit de sécurité</li>
            <li class="rounded-2xl border border-white/80 bg-white/70 px-3 py-2">Surveillance 24/7</li>
            <li class="rounded-2xl border border-white/80 bg-white/70 px-3 py-2">Outils de détection d’intrusion</li>
            <li class="rounded-2xl border border-white/80 bg-white/70 px-3 py-2">Formations</li>
            <li class="rounded-2xl border border-white/80 bg-white/70 px-3 py-2">Gestion des accès</li>
            <li class="rounded-2xl border border-white/80 bg-white/70 px-3 py-2">Recommandations d’amélioration</li>
          </ul>
        </article>

        <article class="relative overflow-hidden rounded-[2.25rem] border border-blue-100 bg-white p-7 shadow-[0_16px_40px_-30px_rgba(15,23,42,0.28)] xl:col-span-5 xl:min-h-[17rem]">
          <div class="absolute -left-10 bottom-0 h-32 w-32 rounded-full bg-sky-100/50 blur-2xl"></div>
          <div class="flex items-center justify-between gap-4">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-700">Cloud</p>
            <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">Essentiel</span>
          </div>
          <h2 class="mt-3 text-2xl font-semibold text-slate-950">Cloud, continuité et mobilité</h2>
          <p class="mt-3 max-w-md text-sm leading-6 text-slate-600">
            Des services qui facilitent l’accès, la sauvegarde et la collaboration sans compliquer l’exploitation.
          </p>
          <div class="mt-6 grid gap-3 text-sm leading-6 text-slate-600 sm:grid-cols-2">
            <span class="rounded-2xl border border-slate-100 bg-slate-50/80 px-3 py-2">Sauvegarde</span>
            <span class="rounded-2xl border border-slate-100 bg-slate-50/80 px-3 py-2">Microsoft 365 / Google</span>
            <span class="rounded-2xl border border-slate-100 bg-slate-50/80 px-3 py-2">Téléphonie IP</span>
            <span class="rounded-2xl border border-slate-100 bg-slate-50/80 px-3 py-2">Migrations et maintien de service</span>
            <span class="rounded-2xl border border-slate-100 bg-slate-50/80 px-3 py-2">Gestion des courriels</span>
            <span class="rounded-2xl border border-slate-100 bg-slate-50/80 px-3 py-2">Collaboration à distance</span>
          </div>
        </article>

        <article class="relative overflow-hidden rounded-[2.25rem] border border-blue-100 bg-white p-7 shadow-[0_16px_40px_-30px_rgba(15,23,42,0.22)] xl:col-span-4">
          <div class="flex items-center justify-between gap-4">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-700">Loi 25</p>
            <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">Conformité</span>
          </div>
          <h2 class="mt-3 text-2xl font-semibold text-slate-950">Conformité à la Loi 25</h2>
          <p class="mt-3 text-sm leading-6 text-slate-600">
            Nous vous accompagnons avec une démarche simple, structurée et adaptée à votre réalité.
          </p>
          <ul class="mt-5 grid gap-3 text-sm leading-6 text-slate-600">
            <li class="rounded-2xl border border-slate-100 bg-slate-50/80 px-3 py-2">Évaluation des obligations</li>
            <li class="rounded-2xl border border-slate-100 bg-slate-50/80 px-3 py-2">Politiques et procédures</li>
            <li class="rounded-2xl border border-slate-100 bg-slate-50/80 px-3 py-2">Sensibilisation des équipes</li>
            <li class="rounded-2xl border border-slate-100 bg-slate-50/80 px-3 py-2">Support à la mise en place</li>
          </ul>
        </article>

        <article class="relative overflow-hidden rounded-[2.25rem] border border-blue-100 bg-gradient-to-br from-white to-slate-50 p-7 shadow-[0_16px_40px_-30px_rgba(15,23,42,0.24)] xl:col-span-8">
          <div class="flex items-center justify-between gap-4">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-700">Technique</p>
            <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">Terrain</span>
          </div>
          <h2 class="mt-3 text-2xl font-semibold text-slate-950">Installation, réparation et support Microsoft</h2>
          <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600">
            Nous offrons aussi des services de techniciens pour aider vos équipes au quotidien.
          </p>
          <ul class="mt-6 grid gap-3 text-sm leading-6 text-slate-600 sm:grid-cols-2">
            <li class="rounded-2xl border border-white/80 bg-white/80 px-3 py-2">Support Microsoft 365, Windows et postes de travail</li>
            <li class="rounded-2xl border border-white/80 bg-white/80 px-3 py-2">Installation de matériel, logiciels et périphériques</li>
            <li class="rounded-2xl border border-white/80 bg-white/80 px-3 py-2">Réparation, dépannage et mise en service</li>
            <li class="rounded-2xl border border-white/80 bg-white/80 px-3 py-2">Configuration réseau et assistance sur site ou à distance</li>
          </ul>
        </article>

        <article class="relative overflow-hidden rounded-[2.25rem] border border-blue-100 bg-gradient-to-br from-blue-50 to-white p-7 shadow-[0_16px_40px_-30px_rgba(37,99,235,0.28)] xl:col-span-4">
          <div class="flex items-center justify-between gap-4">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-700">Bâtiments</p>
            <span class="rounded-full bg-white/80 px-3 py-1 text-xs font-semibold text-slate-600">Connecté</span>
          </div>
          <h2 class="mt-3 text-2xl font-semibold text-slate-950">Infrastructure et surveillance</h2>
          <p class="mt-3 text-sm leading-6 text-slate-600">
            Des solutions pour relier votre espace, votre réseau et vos équipements de façon fiable.
          </p>
          <ul class="mt-5 grid gap-3 text-sm leading-6 text-slate-600">
            <li class="rounded-2xl border border-white/80 bg-white/80 px-3 py-2">Câblage</li>
            <li class="rounded-2xl border border-white/80 bg-white/80 px-3 py-2">Surveillance</li>
            <li class="rounded-2xl border border-white/80 bg-white/80 px-3 py-2">Objets IoT</li>
            <li class="rounded-2xl border border-white/80 bg-white/80 px-3 py-2">Internet</li>
          </ul>
        </article>

        <article class="relative overflow-hidden rounded-[2.25rem] border border-slate-200 bg-slate-950 px-7 py-8 text-white shadow-[0_30px_70px_-35px_rgba(15,23,42,0.9)] xl:col-span-12 md:px-10">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(59,130,246,0.12),transparent_28%),radial-gradient(circle_at_left,rgba(14,165,233,0.07),transparent_24%)]"></div>
          <div class="relative flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
            <div class="max-w-4xl">
              <p class="text-sm font-semibold uppercase tracking-[0.24em] text-blue-300">Zone desservie</p>
              <h2 class="mt-4 text-3xl font-semibold tracking-tight md:text-4xl">
                Lac-Saint-Jean, Saguenay et au-delà.
              </h2>
              <p class="mt-4 max-w-3xl text-sm leading-7 text-slate-300">
                Nous intervenons principalement au Lac-Saint-Jean et au Saguenay. Selon la nature du mandat, il est aussi possible de travailler en dehors de ces secteurs.
              </p>
              <div class="mt-6 flex flex-wrap gap-3">
                <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-slate-200">Sur site</span>
                <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-slate-200">À distance</span>
                <span class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-slate-200">Interventions sur demande</span>
              </div>
            </div>

            <div class="flex w-full flex-col gap-3 sm:w-auto sm:min-w-[260px] lg:items-end">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-300">Réponse rapide</p>
              <a href="/contact" class="inline-flex w-fit rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:bg-blue-100">
                Planifier un échange
              </a>
              <p class="max-w-sm text-sm leading-6 text-slate-300 sm:text-right">
                On vous revient avec une réponse claire et adaptée à votre réalité.
              </p>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 pb-16 md:pb-24">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-blue-700">FAQ</p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight text-slate-950">
          Questions fréquentes sur nos services.
        </h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          Cette section aide vos visiteurs à trouver rapidement l’information la plus importante et renforce la pertinence SEO de la page.
        </p>
      </div>

      <div class="mt-8 grid gap-4">
        {faqItems.map((item) => (
          <details class="group rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm transition open:border-blue-200 open:bg-blue-50">
            <summary class="cursor-pointer list-none text-lg font-semibold text-slate-950">
              <span class="flex items-center justify-between gap-4">
                <span>{item.question}</span>
                <span class="text-blue-700 transition group-open:rotate-45">+</span>
              </span>
            </summary>
            <p class="mt-4 max-w-3xl text-sm leading-7 text-slate-600">
              {item.answer}
            </p>
          </details>
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 pb-20 md:pb-28">
      <div class="rounded-[2.5rem] border border-slate-200 bg-slate-950 px-7 py-10 text-white shadow-[0_30px_70px_-35px_rgba(15,23,42,0.9)] md:px-10">
        <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-end">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-blue-300">Prêt à avancer</p>
            <h2 class="mt-4 max-w-2xl text-3xl font-semibold tracking-tight md:text-4xl">
              Une meilleure présence visuelle, c’est aussi une meilleure impression de maîtrise.
            </h2>
            <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">
              Si tu veux, on peut maintenant pousser plus loin la page avec des preuves sociales, des témoignages ou un autre polish du contenu.
            </p>
          </div>
          <a href="/contact" class="inline-flex w-fit rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:bg-blue-100">
            Lancer une demande
          </a>
        </div>
      </div>
    </section>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
</BaseLayout>
