---
import BaseLayout from "../layouts/BaseLayout.astro";

const faqItems = [
  {
    question: "Quels types de services offrez-vous?",
    answer:
      "Nous offrons des services de cybersécurité, de cloud, de conformité à la Loi 25, de communication unifiée, de support technique et de bâtiments connectés.",
  },
  {
    question: "Comment se déroule un audit de sécurité?",
    answer:
      "L’audit de sécurité commence par un tour du parc informatique, des services utilisés, des accès et des équipements en place afin d’identifier les risques, les priorités et les améliorations à apporter.",
  },
  {
    question: "Offrez-vous du support Microsoft 365?",
    answer:
      "Oui. Nous pouvons vous accompagner pour Microsoft 365, Windows, les postes de travail, la configuration et le support courant.",
  },
  {
    question: "Pouvez-vous nous aider avec la Loi 25?",
    answer:
      "Oui. Nous offrons de l’accompagnement pour la conformité à la Loi 25, avec évaluation des obligations, politiques, procédures et mise en place.",
  },
  {
    question: "Faites-vous de l’installation et de la réparation?",
    answer:
      "Oui. Notre volet technique couvre l’installation, la réparation, le dépannage, la mise en service et l’assistance à distance ou sur site.",
  },
  {
    question: "Travaillez-vous aussi en dehors des heures d’ouverture?",
    answer:
      "Oui. Nous restons disponibles en dehors des heures aussi selon la nature du besoin et le niveau d’urgence.",
  },
  {
    question: "Offrez-vous des services sur site?",
    answer:
      "Oui. Nous pouvons intervenir à distance ou sur site, selon le service et la situation.",
  },
];

const serviceTickerItems = [
  "Cybersécurité",
  "Cloud",
  "Loi 25",
  "Support Microsoft 365",
  "Téléphonie IP",
  "Bâtiments connectés",
  "Sauvegarde",
  "Audit de sécurité",
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<BaseLayout title="Services | Evolution Cloud">
  <main class="overflow-hidden">
    <section class="relative isolate mx-auto max-w-7xl px-6 py-16 md:py-24">
      <div class="absolute -left-24 top-10 h-72 w-72 rounded-full bg-blue-100/70 blur-3xl"></div>
      <div class="absolute right-0 top-0 h-80 w-80 rounded-full bg-sky-100/60 blur-3xl"></div>
      <div class="absolute inset-x-0 top-20 h-px bg-gradient-to-r from-transparent via-blue-200/70 to-transparent"></div>

      <div class="relative">
        <div class="flex flex-col justify-center">
          <p class="inline-flex w-fit rounded-full border border-blue-200 bg-white/85 px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-blue-700 shadow-sm backdrop-blur">
            Nos services
          </p>
          <h1 class="mt-5 max-w-3xl text-4xl font-semibold tracking-tight text-slate-950 md:text-6xl">
            Une offre claire, structurée et rassurante pour vos opérations.
          </h1>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600">
            Evolution Cloud accompagne les entreprises en cybersécurité, cloud, Loi 25, communication unifiée, bâtiments connectés et support technique.
            L’idée est simple: des services concrets, bien cadrés et utiles au quotidien.
          </p>
          <p class="mt-4 max-w-3xl text-sm leading-7 text-slate-600">
            Nous desservons principalement le Lac-Saint-Jean et le Saguenay, avec possibilité d’interventions ailleurs selon le besoin.
          </p>
        </div>
      </div>
    </section>

    <section class="relative mx-auto max-w-6xl px-6 pb-16 md:pb-24">
      <div class="pointer-events-none absolute inset-x-8 top-10 h-44 rounded-full bg-blue-100/30 blur-3xl"></div>
      <div class="grid gap-4 xl:grid-cols-12 xl:auto-rows-fr">
        <article class="group relative overflow-hidden rounded-[2.1rem] border border-blue-100 bg-gradient-to-br from-blue-50/70 via-white to-white shadow-[0_18px_48px_-38px_rgba(37,99,235,0.32)] xl:col-span-7">
          <div class="absolute inset-x-0 top-0 h-1 bg-transparent"></div>
          <div class="px-6 pb-6 pt-7 md:px-7 md:pb-7">
            <div class="flex items-start gap-4">
              <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full border border-blue-100 bg-white shadow-[0_12px_25px_-18px_rgba(37,99,235,0.4)]">
                <svg viewBox="0 0 24 24" class="h-7 w-7 text-blue-600" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 3l7 3v5c0 4.2-2.7 7.8-7 10-4.3-2.2-7-5.8-7-10V6l7-3Z" />
                  <path d="M9.5 12.5 11.4 14.4 15.2 10.6" />
                </svg>
              </div>
              <div class="flex-1">
                <div class="flex items-center justify-between gap-4">
                  <p class="text-[0.66rem] font-semibold uppercase tracking-[0.34em] text-blue-700">Cybersécurité</p>
                  <span class="rounded-full bg-white/80 px-3 py-1 text-[0.72rem] font-semibold text-blue-700 shadow-sm">Priorité haute</span>
                </div>
                <h2 class="mt-3 max-w-xl text-[2.15rem] leading-[1.04] font-semibold tracking-tight text-slate-950">
                  Protection de vos environnements
                </h2>
              </div>
            </div>
            <p class="mt-5 max-w-2xl text-[0.96rem] leading-7 text-slate-600">
              On sécurise vos systèmes avec une approche réaliste, orientée prévention, détection et réponse.
            </p>
            <div class="mt-7 grid gap-3 sm:grid-cols-2">
              <div class="rounded-2xl border border-slate-100 bg-white/90 px-4 py-3 text-sm text-slate-700 shadow-[0_8px_20px_-18px_rgba(15,23,42,0.35)]">Audit de sécurité</div>
              <div class="rounded-2xl border border-slate-100 bg-white/90 px-4 py-3 text-sm text-slate-700 shadow-[0_8px_20px_-18px_rgba(15,23,42,0.35)]">Surveillance 24/7</div>
              <div class="rounded-2xl border border-slate-100 bg-white/90 px-4 py-3 text-sm text-slate-700 shadow-[0_8px_20px_-18px_rgba(15,23,42,0.35)]">Outils de détection d’intrusion</div>
              <div class="rounded-2xl border border-slate-100 bg-white/90 px-4 py-3 text-sm text-slate-700 shadow-[0_8px_20px_-18px_rgba(15,23,42,0.35)]">Formations</div>
              <div class="rounded-2xl border border-slate-100 bg-white/90 px-4 py-3 text-sm text-slate-700 shadow-[0_8px_20px_-18px_rgba(15,23,42,0.35)]">Gestion des accès</div>
              <div class="rounded-2xl border border-slate-100 bg-white/90 px-4 py-3 text-sm text-slate-700 shadow-[0_8px_20px_-18px_rgba(15,23,42,0.35)]">Recommandations d’amélioration</div>
            </div>
          </div>
        </article>

        <article class="group relative overflow-hidden rounded-[2.1rem] border border-blue-100 bg-white shadow-[0_18px_48px_-38px_rgba(15,23,42,0.24)] xl:col-span-5">
          <div class="px-6 pb-6 pt-7 md:px-7 md:pb-7">
            <div class="flex items-start gap-4">
              <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full border border-blue-100 bg-blue-50 shadow-[0_12px_25px_-18px_rgba(37,99,235,0.35)]">
                <svg viewBox="0 0 24 24" class="h-7 w-7 text-blue-500" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5.5 15.5A4.5 4.5 0 1 1 8 7h1.2A5 5 0 1 1 14 15.5" />
                  <path d="M8 15.5h8.8A3.2 3.2 0 0 0 16.4 9H16" />
                </svg>
              </div>
              <div class="flex-1">
                <div class="flex items-center justify-between gap-4">
                  <p class="text-[0.66rem] font-semibold uppercase tracking-[0.34em] text-blue-700">Cloud</p>
                  <span class="rounded-full bg-blue-50 px-3 py-1 text-[0.72rem] font-semibold text-blue-700">Essentiel</span>
                </div>
                <h2 class="mt-3 max-w-sm text-[2.15rem] leading-[1.04] font-semibold tracking-tight text-slate-950">
                  Cloud, continuité et mobilité
                </h2>
              </div>
            </div>
            <p class="mt-5 max-w-md text-[0.96rem] leading-7 text-slate-600">
              Des services qui facilitent l’accès, la sauvegarde et la collaboration sans compliquer l’exploitation.
            </p>
            <div class="mt-7 grid gap-3 sm:grid-cols-2">
              <div class="rounded-2xl border border-slate-100 bg-slate-50/80 px-4 py-3 text-sm text-slate-700">Sauvegarde</div>
              <div class="rounded-2xl border border-slate-100 bg-slate-50/80 px-4 py-3 text-sm text-slate-700">Microsoft 365 / Google</div>
              <div class="rounded-2xl border border-slate-100 bg-slate-50/80 px-4 py-3 text-sm text-slate-700">Téléphonie IP</div>
              <div class="rounded-2xl border border-slate-100 bg-slate-50/80 px-4 py-3 text-sm text-slate-700">Migrations et maintien de service</div>
            </div>
          </div>
        </article>

        <article class="group relative overflow-hidden rounded-[2.1rem] border border-blue-100 bg-white shadow-[0_18px_48px_-38px_rgba(15,23,42,0.2)] xl:col-span-4">
          <div class="px-6 pb-6 pt-7 md:px-7 md:pb-7">
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-blue-100 bg-white shadow-[0_12px_25px_-18px_rgba(37,99,235,0.28)]">
                <svg viewBox="0 0 24 24" class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M6 3h9l3 3v15H6z" />
                  <path d="M15 3v4h4" />
                  <path d="M8 11h8" />
                  <path d="M8 15h8" />
                </svg>
              </div>
              <div class="flex-1">
                <div class="flex items-center justify-between gap-4">
                  <p class="text-[0.66rem] font-semibold uppercase tracking-[0.34em] text-blue-700">Loi 25</p>
                  <span class="rounded-full bg-blue-50 px-3 py-1 text-[0.72rem] font-semibold text-blue-700">Conformité</span>
                </div>
                <h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">
                  Conformité à la Loi 25
                </h2>
              </div>
            </div>
            <p class="mt-4 text-sm leading-6 text-slate-600">
              Nous vous accompagnons avec une démarche simple, structurée et adaptée à votre réalité.
            </p>
            <ul class="mt-5 space-y-2 text-sm leading-6 text-slate-600">
              <li class="flex items-center justify-between rounded-2xl border border-slate-100 bg-slate-50/80 px-4 py-3"><span>Évaluation des obligations</span><span class="text-slate-400">›</span></li>
              <li class="flex items-center justify-between rounded-2xl border border-slate-100 bg-slate-50/80 px-4 py-3"><span>Politiques et procédures</span><span class="text-slate-400">›</span></li>
              <li class="flex items-center justify-between rounded-2xl border border-slate-100 bg-slate-50/80 px-4 py-3"><span>Sensibilisation des équipes</span><span class="text-slate-400">›</span></li>
              <li class="flex items-center justify-between rounded-2xl border border-slate-100 bg-slate-50/80 px-4 py-3"><span>Support à la mise en place</span><span class="text-slate-400">›</span></li>
            </ul>
          </div>
        </article>

        <article class="group relative overflow-hidden rounded-[2.1rem] border border-blue-100 bg-gradient-to-br from-white to-slate-50 shadow-[0_18px_48px_-38px_rgba(15,23,42,0.24)] xl:col-span-8">
          <div class="px-6 pb-6 pt-7 md:px-7 md:pb-7">
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-blue-100 bg-blue-50 shadow-[0_12px_25px_-18px_rgba(37,99,235,0.28)]">
                <svg viewBox="0 0 24 24" class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="4" y="5" width="16" height="11" rx="1.8" />
                  <path d="M8 19h8" />
                  <path d="M10 16v3" />
                  <path d="M14 16v3" />
                </svg>
              </div>
              <div class="flex-1">
                <div class="flex items-center justify-between gap-4">
                  <p class="text-[0.66rem] font-semibold uppercase tracking-[0.34em] text-blue-700">Technique</p>
                  <span class="rounded-full bg-blue-50 px-3 py-1 text-[0.72rem] font-semibold text-blue-700">Terrain</span>
                </div>
                <h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">
                  Installation, réparation et support Microsoft
                </h2>
              </div>
            </div>
            <p class="mt-4 max-w-2xl text-sm leading-6 text-slate-600">
              Nous offrons aussi des services de techniciens pour aider vos équipes au quotidien.
            </p>
            <div class="mt-6 grid gap-3 md:grid-cols-2">
              <div class="flex items-start gap-3 rounded-2xl border border-white/90 bg-white/85 px-4 py-4 shadow-[0_8px_20px_-18px_rgba(15,23,42,0.35)]">
                <span class="mt-0.5 text-blue-700">▢</span>
                <p class="text-sm leading-6 text-slate-700">Support Microsoft 365, Windows et postes de travail</p>
              </div>
              <div class="flex items-start gap-3 rounded-2xl border border-white/90 bg-white/85 px-4 py-4 shadow-[0_8px_20px_-18px_rgba(15,23,42,0.35)]">
                <span class="mt-0.5 text-blue-700">▢</span>
                <p class="text-sm leading-6 text-slate-700">Installation de matériel, logiciels et périphériques</p>
              </div>
              <div class="flex items-start gap-3 rounded-2xl border border-white/90 bg-white/85 px-4 py-4 shadow-[0_8px_20px_-18px_rgba(15,23,42,0.35)]">
                <span class="mt-0.5 text-blue-700">▢</span>
                <p class="text-sm leading-6 text-slate-700">Réparation, dépannage et mise en service</p>
              </div>
              <div class="flex items-start gap-3 rounded-2xl border border-white/90 bg-white/85 px-4 py-4 shadow-[0_8px_20px_-18px_rgba(15,23,42,0.35)]">
                <span class="mt-0.5 text-blue-700">▢</span>
                <p class="text-sm leading-6 text-slate-700">Configuration réseau et assistance sur site ou à distance</p>
              </div>
            </div>
          </div>
        </article>

        <article class="group relative overflow-hidden rounded-[2.1rem] border border-blue-100 bg-gradient-to-br from-blue-50 to-white shadow-[0_18px_48px_-38px_rgba(37,99,235,0.22)] xl:col-span-4">
          <div class="px-6 pb-6 pt-7 md:px-7 md:pb-7">
            <div class="flex items-start gap-4">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full border border-blue-100 bg-white shadow-[0_12px_25px_-18px_rgba(37,99,235,0.26)]">
                <svg viewBox="0 0 24 24" class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 7h16v10H4z" />
                  <path d="M10 17v3" />
                  <path d="M7 20h10" />
                  <path d="M8 10h8" />
                </svg>
              </div>
              <div class="flex-1">
                <div class="flex items-center justify-between gap-4">
                  <p class="text-[0.66rem] font-semibold uppercase tracking-[0.34em] text-blue-700">Bâtiments</p>
                  <span class="rounded-full bg-white/80 px-3 py-1 text-[0.72rem] font-semibold text-slate-600">Connecté</span>
                </div>
                <h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950">
                  Infrastructure et surveillance
                </h2>
              </div>
            </div>
            <p class="mt-4 text-sm leading-6 text-slate-600">
              Des solutions pour relier votre espace, votre réseau et vos équipements de façon fiable.
            </p>
            <ul class="mt-5 space-y-2 text-sm leading-6 text-slate-600">
              <li class="flex items-center justify-between rounded-2xl border border-white/90 bg-white/85 px-4 py-3 shadow-[0_8px_20px_-18px_rgba(15,23,42,0.35)]"><span>Câblage</span><span class="text-slate-400">›</span></li>
              <li class="flex items-center justify-between rounded-2xl border border-white/90 bg-white/85 px-4 py-3 shadow-[0_8px_20px_-18px_rgba(15,23,42,0.35)]"><span>Surveillance</span><span class="text-slate-400">›</span></li>
              <li class="flex items-center justify-between rounded-2xl border border-white/90 bg-white/85 px-4 py-3 shadow-[0_8px_20px_-18px_rgba(15,23,42,0.35)]"><span>Objets IoT</span><span class="text-slate-400">›</span></li>
              <li class="flex items-center justify-between rounded-2xl border border-white/90 bg-white/85 px-4 py-3 shadow-[0_8px_20px_-18px_rgba(15,23,42,0.35)]"><span>Internet</span><span class="text-slate-400">›</span></li>
            </ul>
          </div>
        </article>

        <article class="relative overflow-hidden rounded-[2.1rem] border border-slate-200 bg-slate-950 shadow-[0_30px_70px_-35px_rgba(15,23,42,0.9)] xl:col-span-8">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(59,130,246,0.14),transparent_28%),radial-gradient(circle_at_right,rgba(14,165,233,0.09),transparent_22%)]"></div>
          <div class="relative px-6 py-8 text-white md:px-10 md:py-10">
            <div class="max-w-4xl">
              <p class="text-[0.68rem] font-semibold uppercase tracking-[0.34em] text-blue-300">Zone desservie</p>
              <h2 class="mt-4 text-3xl font-semibold tracking-tight md:text-4xl">
                Lac-Saint-Jean, Saguenay et au-delà.
              </h2>
              <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">
                Nous intervenons principalement au Lac-Saint-Jean et au Saguenay. Selon la nature du mandat, il est aussi possible de travailler en dehors de ces secteurs.
              </p>
            </div>
            <div class="mt-8 flex flex-col gap-4 rounded-[1.6rem] border border-white/10 bg-white/5 p-5 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <p class="text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-blue-300">Parlons de vos besoins</p>
                <p class="mt-2 text-sm leading-6 text-slate-300">
                  On vous revient avec une réponse claire et adaptée à votre réalité.
                </p>
              </div>
              <a href="/contact" class="inline-flex w-fit rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:bg-blue-100">
                Obtenez une évaluation gratuite
              </a>
            </div>
          </div>
        </article>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 pb-16 md:pb-24">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-blue-700">FAQ</p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight text-slate-950">
          Questions fréquentes sur nos services.
        </h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          Cette section aide vos visiteurs à trouver rapidement l’information la plus importante et renforce la pertinence SEO de la page.
        </p>
      </div>

      <div class="mt-8 grid gap-4">
        {faqItems.map((item) => (
          <details class="group rounded-[1.75rem] border border-slate-200 bg-white p-6 shadow-sm transition open:border-blue-200 open:bg-blue-50">
            <summary class="cursor-pointer list-none text-lg font-semibold text-slate-950">
              <span class="flex items-center justify-between gap-4">
                <span>{item.question}</span>
                <span class="text-blue-700 transition group-open:rotate-45">+</span>
              </span>
            </summary>
            <p class="mt-4 max-w-3xl text-sm leading-7 text-slate-600">
              {item.answer}
            </p>
          </details>
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 pb-20 md:pb-28">
      <div class="rounded-[2.5rem] border border-slate-200 bg-slate-950 px-7 py-10 text-white shadow-[0_30px_70px_-35px_rgba(15,23,42,0.9)] md:px-10">
        <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-end">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-blue-300">Prêt à avancer</p>
            <h2 class="mt-4 max-w-2xl text-3xl font-semibold tracking-tight md:text-4xl">
              Besoin d’un accompagnement clair en cybersécurité, cloud ou support technique?
            </h2>
            <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">
              On peut vous aider à structurer vos besoins, prioriser les actions et mettre en place une solution adaptée à votre réalité.
            </p>
          </div>
          <a href="/contact" class="inline-flex w-fit rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:bg-blue-100">
            Parler à un expert
          </a>
        </div>
      </div>
    </section>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
</BaseLayout>
