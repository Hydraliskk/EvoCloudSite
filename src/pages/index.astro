---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Accueil | Evolution Cloud">
  <main class="overflow-hidden">
    <section class="relative isolate">
      <div class="absolute inset-x-0 top-0 h-[640px] bg-[radial-gradient(circle_at_top,rgba(37,99,235,0.22),transparent_46%),radial-gradient(circle_at_80%_15%,rgba(14,165,233,0.18),transparent_28%),linear-gradient(180deg,rgba(255,255,255,0.92),rgba(248,250,252,0.15))]"></div>
      <div class="relative mx-auto grid max-w-6xl gap-12 px-6 py-16 md:grid-cols-[1.02fr_0.98fr] md:items-center md:py-24">
        <div class="flex flex-col justify-center">
          <p class="inline-flex w-fit rounded-full border border-blue-200 bg-white/85 px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-blue-700 shadow-sm backdrop-blur">
            Services TI et cybersécurité
          </p>
          <h1 class="mt-5 max-w-2xl text-4xl font-semibold tracking-tight text-slate-950 md:text-6xl">
            Des solutions technologiques plus claires, plus solides et plus simples à faire vivre.
          </h1>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
            Evolution Cloud accompagne les entreprises avec la cybersécurité, le cloud, la conformité et le support technique.
            On met en place des bases solides, humaines et faciles à maintenir dans le temps.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="/services"
              class="rounded-full bg-slate-950 px-6 py-3 text-sm font-semibold text-white shadow-[0_18px_32px_-18px_rgba(15,23,42,0.9)] transition hover:-translate-y-0.5 hover:bg-blue-700"
            >
              Découvrir les services
            </a>
            <a
              href="/contact"
              class="rounded-full border border-slate-300 bg-white/70 px-6 py-3 text-sm font-semibold text-slate-700 backdrop-blur transition hover:border-blue-300 hover:text-blue-700"
            >
              Nous contacter
            </a>
          </div>

          <div class="mt-10 grid gap-4 sm:grid-cols-3">
            <div class="rounded-[1.5rem] border border-slate-200 bg-white/90 p-4 shadow-sm backdrop-blur">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700">Cybersécurité</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">Audit, détection et accompagnement concret.</p>
            </div>
            <div class="rounded-[1.5rem] border border-slate-200 bg-white/90 p-4 shadow-sm backdrop-blur">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700">Cloud</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">Sauvegarde, mobilité et continuité de service.</p>
            </div>
            <div class="rounded-[1.5rem] border border-slate-200 bg-white/90 p-4 shadow-sm backdrop-blur">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-700">Loi 25</p>
              <p class="mt-2 text-sm leading-6 text-slate-600">Une conformité structurée, sans lourdeur.</p>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-5 rounded-[2.75rem] bg-gradient-to-br from-blue-100 via-sky-50 to-white blur-3xl"></div>
          <div class="relative min-h-[420px] overflow-hidden rounded-[2.5rem] border border-blue-100 bg-white/55 shadow-[0_34px_100px_-44px_rgba(15,23,42,0.28)] backdrop-blur-sm">
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(37,99,235,0.08),transparent_42%),linear-gradient(180deg,rgba(248,250,252,0.88),rgba(255,255,255,0.65))]"></div>
            <div class="absolute inset-0 bg-[linear-gradient(135deg,transparent_0%,transparent_46%,rgba(37,99,235,0.05)_46%,rgba(37,99,235,0.05)_54%,transparent_54%,transparent_100%)]"></div>
            <div class="absolute left-8 top-8 h-20 w-20 rounded-full border border-blue-100 bg-white/70 blur-[0.2px]"></div>
            <div class="absolute right-12 top-14 h-14 w-14 rounded-full border border-sky-100 bg-sky-50/80"></div>
            <div class="absolute bottom-10 left-12 h-24 w-24 rounded-full border border-slate-200 bg-white/60"></div>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 pb-20 md:pb-28">
      <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="rounded-[2.25rem] border border-slate-200 bg-white p-7 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-blue-700">Notre approche</p>
          <h2 class="mt-4 text-3xl font-semibold tracking-tight text-slate-950">
            Une page d'accueil pensée pour donner la bonne impression dès le premier regard.
          </h2>
          <p class="mt-4 text-sm leading-7 text-slate-600">
            L’accueil présente la marque, le ton et la crédibilité. Les services détaillés vivent dans la page dédiée, là où ils ont leur place.
          </p>
        </div>

        <div class="rounded-[2.25rem] border border-slate-200 bg-white p-7 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-blue-700">Services</p>
          <h3 class="mt-4 text-2xl font-semibold tracking-tight text-slate-950">Ce qu’on fait, au bon endroit.</h3>
          <p class="mt-4 text-sm leading-7 text-slate-600">
            La page Services regroupe vos offres telles qu’elles sont, pour garder l’accueil propre, élégant et orienté image de marque.
          </p>
          <div class="mt-6">
            <a
              href="/services"
              class="inline-flex rounded-full border border-blue-200 bg-blue-50 px-5 py-3 text-sm font-semibold text-blue-700 transition hover:border-blue-300 hover:bg-blue-100"
            >
              Voir tous les services
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 pb-20 md:pb-28">
      <div class="rounded-[2.5rem] border border-slate-200 bg-slate-950 px-7 py-10 text-white shadow-[0_30px_70px_-35px_rgba(15,23,42,0.9)] md:px-10">
        <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-end">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-blue-300">Prêt à avancer</p>
            <h2 class="mt-4 max-w-2xl text-3xl font-semibold tracking-tight md:text-4xl">
              Une meilleure présence visuelle, c’est aussi une meilleure impression de maîtrise.
            </h2>
            <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">
              Si tu veux, on peut maintenant pousser plus loin la page avec des preuves sociales, des témoignages ou un autre polish du contenu.
            </p>
          </div>
          <a
            href="/contact"
            class="inline-flex w-fit rounded-full bg-white px-6 py-3 text-sm font-semibold text-slate-950 transition hover:-translate-y-0.5 hover:bg-blue-100"
          >
            Lancer une demande
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
