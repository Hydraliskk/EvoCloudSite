---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Accueil | Evolution Cloud">
  <main class="overflow-hidden">
    <section class="relative isolate">
      <div class="absolute inset-x-0 top-0 h-[760px] bg-[radial-gradient(circle_at_top,rgba(34,211,238,0.16),transparent_46%),radial-gradient(circle_at_80%_15%,rgba(59,130,246,0.18),transparent_28%),linear-gradient(180deg,rgba(4,10,24,0.96),rgba(10,18,38,0.18))]"></div>
      <div class="relative mx-auto flex min-h-[78vh] max-w-7xl flex-col justify-center px-6 py-20 md:py-28">
        <div class="flex max-w-4xl flex-col justify-center">
          <p class="inline-flex w-fit rounded-full border border-cyan-300/35 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.24em] text-cyan-200 shadow-sm backdrop-blur">
            Services TI et cybersécurité
          </p>
          <h1 class="mt-5 max-w-3xl text-4xl font-semibold tracking-tight text-white md:text-6xl">
            Des solutions technologiques plus claires, plus solides et plus simples à faire vivre.
          </h1>
          <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-300">
            Evolution Cloud accompagne les entreprises avec la cybersécurité, le cloud, la conformité et le support technique.
            On met en place des bases solides, humaines et faciles à maintenir dans le temps.
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="/services"
              class="rounded-full border border-cyan-300/30 bg-[linear-gradient(135deg,rgba(34,211,238,0.22),rgba(59,130,246,0.22))] px-6 py-3 text-sm font-semibold text-white shadow-[0_18px_32px_-18px_rgba(14,165,233,0.55)] transition hover:-translate-y-0.5 hover:border-cyan-100/60 hover:bg-[linear-gradient(135deg,rgba(34,211,238,0.32),rgba(59,130,246,0.34))]"
            >
              Découvrir les services
            </a>
            <a
              href="/contact"
              class="rounded-full border border-cyan-300/25 bg-white/5 px-6 py-3 text-sm font-semibold text-slate-200 backdrop-blur transition hover:border-cyan-100/60 hover:text-cyan-100"
            >
              Nous contacter
            </a>
          </div>

          <div class="mt-12 grid gap-4 sm:grid-cols-3">
            <a href="/services#service-cybersecurite" class="group relative block w-full min-h-[176px] overflow-hidden rounded-[1.75rem] border border-cyan-300/45 bg-[linear-gradient(180deg,rgba(4,10,24,0.94),rgba(10,18,38,0.92))] p-6 shadow-[0_28px_70px_-38px_rgba(14,165,233,0.5)] ring-1 ring-cyan-200/24 backdrop-blur transition duration-300 hover:-translate-y-0.5 hover:border-cyan-100/70 hover:shadow-[0_34px_82px_-34px_rgba(34,211,238,0.58)] md:min-h-[196px] md:p-7">
              <div class="absolute inset-0">
                <img src="/images/service-cyber-photo.png" alt="" aria-hidden="true" class="h-full w-full object-cover object-[center_28%] transition duration-500 group-hover:scale-105" />
                <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(2,6,23,0.36),rgba(2,6,23,0.84))]"></div>
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.14),transparent_32%),linear-gradient(135deg,rgba(34,211,238,0.12),transparent_42%,rgba(59,130,246,0.08))] mix-blend-screen opacity-80"></div>
              </div>
              <div class="relative z-10">
                <p class="text-sm font-semibold uppercase tracking-[0.22em] text-cyan-300 transition group-hover:text-cyan-200 md:text-[0.95rem]">Cybersécurité</p>
                <p class="mt-3 text-base leading-7 text-slate-300 transition group-hover:text-slate-200 md:text-lg">Audit, détection et accompagnement concret.</p>
              </div>
            </a>
            <a href="/services#service-cloud" class="group relative block w-full min-h-[176px] overflow-hidden rounded-[1.75rem] border border-cyan-300/45 bg-[linear-gradient(180deg,rgba(4,10,24,0.94),rgba(10,18,38,0.92))] p-6 shadow-[0_28px_70px_-38px_rgba(14,165,233,0.5)] ring-1 ring-cyan-200/24 backdrop-blur transition duration-300 hover:-translate-y-0.5 hover:border-cyan-100/70 hover:shadow-[0_34px_82px_-34px_rgba(34,211,238,0.58)] md:min-h-[196px] md:p-7">
              <div class="absolute inset-0">
                <img src="/images/service-cloud-photo.png" alt="" aria-hidden="true" class="h-full w-full object-cover object-[center_34%] transition duration-500 group-hover:scale-105" />
                <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(2,6,23,0.36),rgba(2,6,23,0.84))]"></div>
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.14),transparent_32%),linear-gradient(135deg,rgba(34,211,238,0.12),transparent_42%,rgba(59,130,246,0.08))] mix-blend-screen opacity-80"></div>
              </div>
              <div class="relative z-10">
                <p class="text-sm font-semibold uppercase tracking-[0.22em] text-cyan-300 transition group-hover:text-cyan-200 md:text-[0.95rem]">Cloud</p>
                <p class="mt-3 text-base leading-7 text-slate-300 transition group-hover:text-slate-200 md:text-lg">Sauvegarde, mobilité et continuité de service.</p>
              </div>
            </a>
            <a href="/services#service-loi-25" class="group relative block w-full min-h-[176px] overflow-hidden rounded-[1.75rem] border border-cyan-300/45 bg-[linear-gradient(180deg,rgba(4,10,24,0.94),rgba(10,18,38,0.92))] p-6 shadow-[0_28px_70px_-38px_rgba(14,165,233,0.5)] ring-1 ring-cyan-200/24 backdrop-blur transition duration-300 hover:-translate-y-0.5 hover:border-cyan-100/70 hover:shadow-[0_34px_82px_-34px_rgba(34,211,238,0.58)] md:min-h-[196px] md:p-7">
              <div class="absolute inset-0">
                <img src="/images/service-law25-photo.png" alt="" aria-hidden="true" class="h-full w-full object-cover object-[center_22%] transition duration-500 group-hover:scale-105" />
                <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(2,6,23,0.36),rgba(2,6,23,0.84))]"></div>
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.14),transparent_32%),linear-gradient(135deg,rgba(34,211,238,0.12),transparent_42%,rgba(59,130,246,0.08))] mix-blend-screen opacity-80"></div>
              </div>
              <div class="relative z-10">
                <p class="text-sm font-semibold uppercase tracking-[0.22em] text-cyan-300 transition group-hover:text-cyan-200 md:text-[0.95rem]">Loi 25</p>
                <p class="mt-3 text-base leading-7 text-slate-300 transition group-hover:text-slate-200 md:text-lg">Une conformité structurée, sans lourdeur.</p>
              </div>
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 pb-20 md:pb-28">
      <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
        <a href="/a-propos" class="group relative overflow-hidden rounded-[2.25rem] border border-cyan-300/45 bg-[linear-gradient(180deg,rgba(4,10,24,0.95),rgba(10,18,38,0.94))] p-7 shadow-[0_32px_82px_-38px_rgba(14,165,233,0.45)] ring-1 ring-cyan-200/24 transition duration-300 hover:-translate-y-0.5 hover:border-cyan-100/70 hover:shadow-[0_38px_90px_-34px_rgba(34,211,238,0.56)]">
          <div class="absolute inset-0">
            <img src="/images/service-tech-photo.png" alt="" aria-hidden="true" class="h-full w-full object-cover object-[center_25%] transition duration-500 group-hover:scale-105" />
            <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(2,6,23,0.36),rgba(2,6,23,0.84))]"></div>
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.14),transparent_32%),linear-gradient(135deg,rgba(34,211,238,0.12),transparent_42%,rgba(59,130,246,0.08))] mix-blend-screen opacity-80"></div>
          </div>
          <div class="relative z-10">
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-cyan-300 transition group-hover:text-cyan-200">Découvrez notre équipe</p>
            <h2 class="mt-4 text-3xl font-semibold tracking-tight text-white">
              Une équipe proche, impliquée et orientée vers vos besoins réels.
            </h2>
            <p class="mt-4 text-sm leading-7 text-slate-300">
              Derrière Evolution Cloud, il y a des gens qui travaillent avec vous, pas seulement pour vous. 
            </p>
            <div class="mt-6">
              <span class="inline-flex rounded-full border border-cyan-300/25 bg-white/5 px-5 py-3 text-sm font-semibold text-cyan-100 transition group-hover:border-cyan-100/60 group-hover:bg-cyan-300/10">
                Découvrir notre équipe
              </span>
            </div>
          </div>
        </a>

        <a href="/services" class="group relative overflow-hidden rounded-[2.25rem] border border-cyan-300/45 bg-[linear-gradient(180deg,rgba(4,10,24,0.95),rgba(10,18,38,0.94))] p-7 shadow-[0_32px_82px_-38px_rgba(14,165,233,0.45)] ring-1 ring-cyan-200/24 transition duration-300 hover:-translate-y-0.5 hover:border-cyan-100/70 hover:shadow-[0_38px_90px_-34px_rgba(34,211,238,0.56)]">
          <div class="absolute inset-0">
            <img src="/images/service-buildings-photo.png" alt="" aria-hidden="true" class="h-full w-full object-cover object-[center_20%] transition duration-500 group-hover:scale-105" />
            <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(2,6,23,0.36),rgba(2,6,23,0.84))]"></div>
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(34,211,238,0.14),transparent_32%),linear-gradient(135deg,rgba(34,211,238,0.12),transparent_42%,rgba(59,130,246,0.08))] mix-blend-screen opacity-80"></div>
          </div>
          <div class="relative z-10">
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-cyan-300 transition group-hover:text-cyan-200">Services</p>
            <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white">Ce qu’on fait, au bon endroit.</h3>
            <p class="mt-4 text-sm leading-7 text-slate-300">
              Découvrez nos nombreux services
            </p>
            <div class="mt-6">
              <span class="inline-flex rounded-full border border-cyan-300/25 bg-white/5 px-5 py-3 text-sm font-semibold text-cyan-100 transition group-hover:border-cyan-100/60 group-hover:bg-cyan-300/10">
                Voir tous les services
              </span>
            </div>
          </div>
        </a>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-6 pb-20 md:pb-28">
      <div class="rounded-[2.5rem] border border-cyan-300/45 bg-[linear-gradient(180deg,rgba(4,10,24,0.96),rgba(2,6,23,1))] px-7 py-10 text-white shadow-[0_38px_118px_-36px_rgba(14,165,233,0.48)] ring-1 ring-cyan-200/24 md:px-10">
        <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-end">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-cyan-300">Prêt à avancer</p>
            <h2 class="mt-4 max-w-2xl text-3xl font-semibold tracking-tight md:text-4xl">
              Vous avez un besoin clair? On peut vous aider à passer à l’action.
            </h2>
            <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-300">
              Parlez-nous de votre contexte, de vos priorités ou de votre échéancier, et on vous répond avec une approche simple, directe et utile.
            </p>
          </div>
          <a
            href="/contact"
            class="inline-flex w-fit rounded-full border border-cyan-300/30 bg-white/5 px-6 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5 hover:bg-cyan-300/14"
          >
            Nous contacter
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
