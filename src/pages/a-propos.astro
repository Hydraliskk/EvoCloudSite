---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="À propos | Evolution Cloud">
  <main class="mx-auto max-w-6xl px-6 py-16 md:py-24">
    <section class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-700">À propos</p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-950 md:text-5xl">
        Une équipe proche des besoins réels des entreprises.
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-600">
        Evolution Cloud aide les organisations à garder le contrôle de leurs outils, à mieux protéger leurs environnements
        et à avancer avec des solutions concrètes, simples et bien accompagnées.
      </p>
    </section>

    <section class="mt-12 grid gap-6 md:grid-cols-3">
      <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-950">Proximité</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">
          Des échanges simples, humains et rapides pour comprendre vos priorités sans jargon inutile.
        </p>
      </article>
      <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-950">Rigueur</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">
          Une approche méthodique pour garder vos systèmes stables, sécurisés et bien encadrés.
        </p>
      </article>
      <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-950">Continuité</h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">
          Un accompagnement qui vise autant la prévention que la durabilité des solutions mises en place.
        </p>
      </article>
    </section>

    <section class="mt-16">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-700">Notre équipe</p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight text-slate-950">
          Des visages clairs derrière un service de proximité.
        </h2>
      </div>

      <div class="mt-8 grid gap-6 md:grid-cols-3">
        <article class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
          <img src="/images/Sabin.jpg" alt="Sabin" class="aspect-[4/5] w-full object-cover object-[50%_10%]" />
          <div class="p-6">
            <h3 class="text-lg font-semibold text-slate-950">Sabin</h3>
            <p class="mt-1 text-sm font-medium text-blue-700">Directeur Général</p>
          </div>
        </article>
        <article class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
          <img src="/images/Tommy.jpg" alt="Tommy" class="aspect-[4/5] w-full object-cover object-[50%_12%]" />
          <div class="p-6">
            <h3 class="text-lg font-semibold text-slate-950">Tommy</h3>
            <p class="mt-1 text-sm font-medium text-blue-700">Directeur des opérations</p>
          </div>
        </article>
        <article class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
          <img src="/images/Charles.png" alt="Charles" class="aspect-[4/5] w-full object-cover object-[50%_18%]" />
          <div class="p-6">
            <h3 class="text-lg font-semibold text-slate-950">Charles</h3>
            <p class="mt-1 text-sm font-medium text-blue-700">Docteur House</p>
          </div>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
