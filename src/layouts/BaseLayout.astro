---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { title = "Evolution Cloud" } = Astro.props;
const description =
  "Evolution Cloud accompagne les entreprises avec des solutions TI, de cybersécurité, de cloud, de conformité et de support technique.";
---

<!doctype html>
<html lang="fr" class="bg-slate-50">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f8fafc" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <title>{title}</title>
  </head>
  <body class="min-h-dvh text-slate-900 antialiased">
    <Header />
    <slot />
    <Footer />
  </body>
</html>
