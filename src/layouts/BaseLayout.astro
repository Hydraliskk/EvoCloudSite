---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { title = "Evolution Cloud" } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Evolution Cloud accompagne les entreprises avec des solutions TI, de cybersécurité, de cloud, de conformité et de support technique."
    />
    <title>{title}</title>
  </head>
  <body class="min-h-dvh bg-slate-50 text-slate-900 antialiased">
    <Header />
    <slot />
    <Footer />
  </body>
</html>
