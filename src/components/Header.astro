---
const pathname = Astro.url.pathname;

const navItems = [
  { href: "/services#service-cybersecurite", label: "Services" },
  { href: "/a-propos", label: "Notre équipe" },
  { href: "/realisations", label: "Réalisations" },
  { href: "/videos", label: "Vidéos" },
];

const isActive = (href: string) =>
  (href.startsWith("/services") && pathname.startsWith("/services")) ||
  (href.startsWith("/videos") && pathname.startsWith("/videos")) ||
  pathname === href ||
  (href !== "/" && pathname.startsWith(href));
---

<header class="sticky top-0 z-50 border-b border-cyan-300/10 bg-[linear-gradient(180deg,rgba(4,10,24,0.78),rgba(10,18,38,0.58))] backdrop-blur-xl">
  <div class="mx-auto flex max-w-[88rem] flex-wrap items-center justify-between gap-3 px-[1.05rem] py-2 md:flex-nowrap md:gap-7 md:px-8 md:py-3">
    <a href="/" class="flex min-w-0 items-center gap-3 md:gap-6">
      <img
        src="/images/Logo.png"
        alt="Evolution Cloud"
        class="h-[4.7rem] w-auto shrink-0 drop-shadow-[0_0_26px_rgba(34,211,238,0.24)] md:h-[6rem]"
      />
      <div class="min-w-0">
        <div class="truncate text-[1.12rem] font-extrabold tracking-tight text-white md:text-[1.35rem] lg:text-[2.05rem]">Evolution Cloud</div>
        <div class="truncate text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-cyan-300 md:text-xs">
          Services TI & cybersécurité
        </div>
      </div>
    </a>

    <nav class="order-3 flex min-w-0 w-full items-center gap-1 overflow-x-auto pb-1 text-sm font-semibold text-slate-200 md:order-none md:w-auto md:gap-1.5 md:overflow-visible md:pb-0 md:text-[0.88rem]">
      {navItems.map((item) => (
        <a
          href={item.href}
          aria-current={isActive(item.href) ? "page" : undefined}
          class:list={[
            "whitespace-nowrap rounded-full px-2.5 py-[0.38rem] transition md:px-3 md:py-[0.45rem]",
            isActive(item.href)
              ? "border border-cyan-300/25 bg-cyan-300/12 text-cyan-100 shadow-[0_0_0_1px_rgba(34,211,238,0.12)_inset]"
              : "border border-transparent hover:border-cyan-300/20 hover:bg-cyan-300/10 hover:text-cyan-100",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="order-2 ml-auto flex items-center gap-2 md:order-none md:gap-5">
      <a
        href="/contact"
        class="shrink-0 rounded-full border border-cyan-100/60 bg-[linear-gradient(135deg,rgba(34,211,238,0.44),rgba(59,130,246,0.4))] px-4 py-[0.4rem] text-sm font-semibold text-white shadow-[0_0_0_1px_rgba(34,211,238,0.2)_inset,0_0_30px_rgba(34,211,238,0.32),0_12px_24px_-16px_rgba(14,165,233,0.72)] transition hover:-translate-y-0.5 hover:border-cyan-50/75 hover:bg-[linear-gradient(135deg,rgba(34,211,238,0.54),rgba(59,130,246,0.5))] hover:shadow-[0_0_0_1px_rgba(34,211,238,0.28)_inset,0_0_42px_rgba(34,211,238,0.48),0_14px_28px_-16px_rgba(14,165,233,0.88)] md:px-[1.2rem] md:py-[0.62rem] md:text-base"
      >
        Demande de service
      </a>
      <a
        href="tel:+14184769408"
        class="hidden flex-col items-center justify-center whitespace-nowrap rounded-full border border-cyan-200/46 bg-[linear-gradient(135deg,rgba(34,211,238,0.2),rgba(59,130,246,0.2))] px-4 py-[0.42rem] text-center font-semibold tracking-[0.04em] text-cyan-50 shadow-[0_0_0_1px_rgba(34,211,238,0.12)_inset,0_0_28px_rgba(34,211,238,0.26)] transition hover:-translate-y-0.5 hover:border-cyan-100/70 hover:bg-[linear-gradient(135deg,rgba(34,211,238,0.3),rgba(59,130,246,0.28))] hover:shadow-[0_0_0_1px_rgba(34,211,238,0.18)_inset,0_0_36px_rgba(34,211,238,0.36)] md:inline-flex"
      >
        <span class="text-[0.64rem] uppercase tracking-[0.2em] text-cyan-200/95">Nous joindre</span>
        <span class="text-[0.95rem] tracking-[0.02em] text-cyan-50">418-476-9408</span>
      </a>
    </div>
  </div>
</header>
